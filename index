  tbody.innerHTML = list.map((s,i) => {
    const name      = sf(s, fld('Name')) || '—';
    const status    = sf(s, fld('Apply Status'));
    const jobRole   = sf(s, 'Job Role (from Job ID (Sync))') || '—';
    const company   = sf(s, 'Company Name (from Job ID (Sync))') || '—';
