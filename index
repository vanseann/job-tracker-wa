<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Job Tracker — Work Abroad Schoters</title>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.29.0/dist/tabler-icons.min.css">
<style>
*{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;font-family:'Plus Jakarta Sans',sans-serif;font-size:14px;background:#f5f5f3;color:#1a1a18}
:root{
  --blue:#378ADD;--blue-bg:#E6F1FB;--blue-dk:#0C447C;
  --green:#639922;--green-bg:#EAF3DE;
  --teal:#0F6E56;--teal-bg:#E1F5EE;
  --amber:#BA7517;--amber-bg:#FAEEDA;
  --red:#A32D2D;--red-bg:#FCEBEB;
  --gray:#5F5E5A;--gray-bg:#F1EFE8;
  --purple:#534AB7;--purple-bg:#EEEDFE;
  --coral:#993C1D;--coral-bg:#FAECE7;
  --border:#e8e6e0;--border2:#d3d1c7;
  --bg:#f5f5f3;--bg2:#fff;--bg3:#f8f8f6;
  --text:#1a1a18;--text2:#5f5e5a;--text3:#8c8b87;
  --r:8px;--rl:12px;
}

/* LOGIN */
.login-wrap{min-height:100vh;display:flex;align-items:center;justify-content:center;background:var(--bg)}
.login-card{background:var(--bg2);border:0.5px solid var(--border);border-radius:var(--rl);padding:40px;width:360px;text-align:center;box-shadow:0 4px 24px rgba(0,0,0,.06)}
.login-icon{width:52px;height:52px;background:var(--blue);border-radius:var(--r);margin:0 auto 18px;display:flex;align-items:center;justify-content:center;color:#fff;font-size:24px}
.login-title{font-size:19px;font-weight:600;margin-bottom:4px}
.login-sub{font-size:13px;color:var(--text3);margin-bottom:26px}
.login-err{color:var(--red);font-size:12px;margin-bottom:10px;display:none;align-items:center;gap:5px;justify-content:center}
.login-input{width:100%;padding:10px 14px;border:0.5px solid var(--border2);border-radius:var(--r);font-size:14px;font-family:inherit;outline:none;margin-bottom:12px;background:var(--bg3);color:var(--text);transition:.15s}
.login-input:focus{border-color:var(--blue);background:#fff}
.login-btn{width:100%;padding:11px;background:var(--blue);color:#fff;border:none;border-radius:var(--r);font-size:14px;font-weight:600;cursor:pointer;font-family:inherit;transition:.15s}
.login-btn:hover{opacity:.9}
.login-note{font-size:11px;color:var(--text3);margin-top:16px}

/* LAYOUT */
.app{display:flex;height:100vh;overflow:hidden}
.sidebar{width:220px;min-width:220px;background:var(--bg2);border-right:0.5px solid var(--border);display:flex;flex-direction:column}
.sb-header{padding:18px 16px;border-bottom:0.5px solid var(--border)}
.sb-brand{font-size:14px;font-weight:600;display:flex;align-items:center;gap:7px}
.sb-brand i{color:var(--blue);font-size:18px}
.sb-sub{font-size:11px;color:var(--text3);margin-top:3px}
.nav-sect{font-size:10px;font-weight:600;color:var(--text3);padding:14px 16px 4px;text-transform:uppercase;letter-spacing:.08em}
.nav-item{display:flex;align-items:center;gap:9px;padding:8px 16px;cursor:pointer;font-size:13px;color:var(--text2);transition:.12s}
.nav-item:hover{background:var(--bg3);color:var(--text)}
.nav-item.active{background:var(--blue-bg);color:var(--blue-dk);font-weight:500}
.nav-item i{font-size:17px}
.sb-footer{margin-top:auto;padding:14px 16px;border-top:0.5px solid var(--border)}
.logout{display:flex;align-items:center;gap:8px;font-size:13px;color:var(--text3);cursor:pointer}
.logout:hover{color:var(--red)}

/* MAIN */
.main{flex:1;overflow:hidden;display:flex;flex-direction:column}
.topbar{background:var(--bg2);border-bottom:0.5px solid var(--border);padding:11px 20px;display:flex;align-items:center;justify-content:space-between;flex-shrink:0}
.topbar-l{display:flex;align-items:center;gap:10px}
.page-title{font-size:15px;font-weight:600}
.topbar-r{display:flex;align-items:center;gap:8px}
.search-box{display:flex;align-items:center;gap:6px;background:var(--bg3);border:0.5px solid var(--border);border-radius:var(--r);padding:7px 11px;width:220px}
.search-box i{font-size:15px;color:var(--text3)}
.search-box input{background:none;border:none;outline:none;font-size:13px;color:var(--text);font-family:inherit;width:100%}
.btn{display:inline-flex;align-items:center;gap:5px;padding:7px 12px;border-radius:var(--r);font-size:13px;font-weight:500;cursor:pointer;border:0.5px solid var(--border2);background:var(--bg2);color:var(--text);font-family:inherit;transition:.12s}
.btn:hover{background:var(--bg3)}
.btn.primary{background:var(--blue);color:#fff;border-color:var(--blue)}
.btn.primary:hover{opacity:.9}
.btn.sm{padding:5px 10px;font-size:12px}
.btn.danger{background:var(--red-bg);color:var(--red);border-color:var(--red)}
.btn:disabled{opacity:.5;cursor:not-allowed}

/* CONTENT */
.content{flex:1;overflow-y:auto;padding:20px}
.page{display:none}
.page.active{display:block}

/* METRICS */
.metrics{display:grid;grid-template-columns:repeat(5,1fr);gap:10px;margin-bottom:20px}
.metric{background:var(--bg3);border-radius:var(--r);padding:14px;cursor:pointer;transition:.12s;border:0.5px solid transparent}
.metric:hover{border-color:var(--border2)}
.metric.sel{border-color:var(--blue);background:var(--blue-bg)}
.metric-lbl{font-size:10px;color:var(--text3);text-transform:uppercase;letter-spacing:.06em;margin-bottom:5px}
.metric-val{font-size:22px;font-weight:600;color:var(--text)}
.metric-sub{font-size:11px;color:var(--text3);margin-top:2px}

/* BADGES */
.badge{display:inline-flex;align-items:center;padding:3px 9px;border-radius:20px;font-size:11px;font-weight:500;white-space:nowrap}
.b-SUB{background:var(--gray-bg);color:var(--gray)}
.b-ADV_DOC{background:var(--blue-bg);color:var(--blue-dk)}
.b-ADV_PAR{background:var(--purple-bg);color:var(--purple)}
.b-ADV_USR{background:var(--teal-bg);color:var(--teal)}
.b-OFF{background:var(--amber-bg);color:var(--amber)}
.b-ACC{background:var(--green-bg);color:var(--green)}
.b-REJ{background:var(--red-bg);color:var(--red)}
.b-null{background:var(--bg3);color:var(--text3)}

/* FILTERS */
.filter-row{display:flex;gap:7px;flex-wrap:wrap;margin-bottom:14px;align-items:center}
.chip{padding:5px 12px;border-radius:20px;font-size:12px;cursor:pointer;border:0.5px solid var(--border2);background:var(--bg2);color:var(--text2);transition:.12s;font-family:inherit}
.chip:hover{background:var(--bg3)}
.chip.active{background:var(--blue);color:#fff;border-color:var(--blue)}

/* TABLE */
.card{background:var(--bg2);border:0.5px solid var(--border);border-radius:var(--rl);overflow:hidden}
.tbl{width:100%;border-collapse:collapse}
.tbl th{text-align:left;padding:10px 14px;font-size:11px;font-weight:600;color:var(--text3);border-bottom:0.5px solid var(--border);background:var(--bg3);text-transform:uppercase;letter-spacing:.04em}
.tbl td{padding:11px 14px;border-bottom:0.5px solid var(--border);color:var(--text);vertical-align:middle;font-size:13px}
.tbl tr:last-child td{border-bottom:none}
.tbl tbody tr{cursor:pointer;transition:.1s}
.tbl tbody tr:hover td{background:var(--blue-bg)}
.avatar{width:32px;height:32px;border-radius:50%;background:var(--blue-bg);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:600;color:var(--blue-dk);flex-shrink:0;overflow:hidden}
.avatar img{width:32px;height:32px;border-radius:50%;object-fit:cover}
.name-cell{display:flex;align-items:center;gap:10px}

/* PIPELINE */
.pipeline{display:flex;gap:12px;overflow-x:auto;padding-bottom:8px;min-height:500px;align-items:flex-start}
.pip-col{min-width:155px;flex:1;max-width:200px}
.pip-head{padding:8px 12px;border-radius:var(--r);margin-bottom:8px;display:flex;align-items:center;justify-content:space-between;font-size:12px;font-weight:600}
.pip-body{display:flex;flex-direction:column;gap:7px;min-height:60px}
.pip-card{background:var(--bg2);border:0.5px solid var(--border);border-radius:var(--r);padding:10px;cursor:pointer;transition:.12s}
.pip-card:hover{border-color:var(--blue)}
.pip-card .pc-name{font-size:12px;font-weight:500;margin-bottom:2px}
.pip-card .pc-prog{font-size:11px;color:var(--text3)}

/* MODAL */
.overlay{position:fixed;inset:0;background:rgba(0,0,0,.38);display:flex;align-items:center;justify-content:center;z-index:1000;padding:20px}
.modal{background:var(--bg2);border-radius:var(--rl);width:100%;max-width:680px;max-height:90vh;overflow-y:auto;padding:24px}
.modal-hdr{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:20px;gap:12px}
.modal-close{background:none;border:none;cursor:pointer;color:var(--text3);font-size:20px;padding:0;line-height:1;flex-shrink:0}
.modal-close:hover{color:var(--text)}
.modal-av{width:56px;height:56px;border-radius:50%;background:var(--blue-bg);display:flex;align-items:center;justify-content:center;font-size:20px;font-weight:600;color:var(--blue-dk);flex-shrink:0;overflow:hidden}
.modal-av img{width:100%;height:100%;object-fit:cover}
.modal-name{font-size:16px;font-weight:600;margin-bottom:3px}
.modal-meta{font-size:12px;color:var(--text3)}
.field-row{display:flex;align-items:flex-start;gap:10px;padding:10px 0;border-bottom:0.5px solid var(--border);font-size:13px}
.field-row:last-child{border-bottom:none}
.field-lbl{width:110px;color:var(--text3);flex-shrink:0;padding-top:1px}
.field-val{flex:1;color:var(--text);font-weight:500;word-break:break-word}
.doc-list{display:flex;flex-direction:column;gap:6px}
.doc-item{display:flex;align-items:center;gap:8px;padding:7px 10px;background:var(--bg3);border-radius:var(--r);font-size:12px;border:0.5px solid var(--border)}
.doc-item i{color:var(--text3);font-size:16px;flex-shrink:0}
.doc-item a{color:var(--blue);text-decoration:none;flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.doc-item a:hover{text-decoration:underline}
.status-section{margin-top:16px;padding-top:16px;border-top:0.5px solid var(--border)}
.status-lbl{font-size:11px;font-weight:600;color:var(--text3);text-transform:uppercase;letter-spacing:.07em;margin-bottom:10px}
.status-grid{display:flex;flex-wrap:wrap;gap:7px}
.s-opt{padding:6px 13px;border-radius:20px;font-size:12px;font-weight:500;cursor:pointer;border:1.5px solid transparent;transition:.12s;font-family:inherit}
.s-opt:hover{opacity:.85}
.s-opt.sel{border-width:2px;font-weight:600}

/* SETTINGS */
.settings-sect{background:var(--bg2);border:0.5px solid var(--border);border-radius:var(--rl);padding:20px;margin-bottom:14px}
.settings-title{font-size:13px;font-weight:600;margin-bottom:14px;display:flex;align-items:center;gap:8px;color:var(--text)}
.settings-title i{color:var(--blue)}
.form-group{margin-bottom:12px}
.form-lbl{font-size:12px;font-weight:500;color:var(--text2);margin-bottom:5px;display:block}
.form-inp{width:100%;padding:8px 12px;border:0.5px solid var(--border2);border-radius:var(--r);font-size:13px;font-family:inherit;outline:none;background:var(--bg3);color:var(--text);transition:.15s}
.form-inp:focus{border-color:var(--blue);background:#fff}
.form-note{font-size:11px;color:var(--text3);margin-top:4px}
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:12px}

/* UTILS */
.loading{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:60px;color:var(--text3);gap:12px}
.spinner{width:28px;height:28px;border:2.5px solid var(--border);border-top-color:var(--blue);border-radius:50%;animation:spin .7s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.empty{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:60px;color:var(--text3);gap:8px;font-size:13px;text-align:center}
.empty i{font-size:40px;color:var(--border2)}
.no-cfg{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:80px 20px;text-align:center;gap:12px}
.no-cfg i{font-size:48px;color:var(--border2)}
.no-cfg h3{font-size:16px;font-weight:600}
.no-cfg p{font-size:13px;color:var(--text3);max-width:300px;line-height:1.6}
.toast{position:fixed;bottom:24px;right:24px;background:#1a1a18;color:#fff;padding:12px 18px;border-radius:var(--r);font-size:13px;z-index:2000;animation:fadeup .2s ease;display:flex;align-items:center;gap:8px;max-width:320px}
.toast.ok i{color:#7cd267}
.toast.err i{color:#f09595}
@keyframes fadeup{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}
.two-col{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:20px}
.prog-bars{display:flex;flex-direction:column;gap:9px}
.prog-row{display:flex;align-items:center;gap:10px;font-size:12px}
.prog-nm{width:92px;color:var(--text2);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.prog-track{flex:1;height:5px;background:var(--bg3);border-radius:3px;overflow:hidden}
.prog-fill{height:100%;border-radius:3px;transition:width .5s}
.prog-n{width:22px;text-align:right;font-weight:500}
.sect-title{font-size:13px;font-weight:600;margin-bottom:12px;display:flex;align-items:center;justify-content:space-between}
.pill-prog{padding:2px 8px;border-radius:20px;font-size:11px;font-weight:500}
.p-English{background:var(--blue-bg);color:var(--blue-dk)}
.p-Ausbildung{background:var(--coral-bg);color:var(--coral)}
.p-Tokutei{background:var(--teal-bg);color:var(--teal)}

/* DOC CARDS */
.sect-hdr{font-size:11px;font-weight:600;color:var(--text3);text-transform:uppercase;letter-spacing:.07em;margin:16px 0 8px;padding-bottom:6px;border-bottom:0.5px solid var(--border);display:flex;align-items:center;justify-content:space-between}
.sect-hdr span{font-weight:400;font-size:11px;color:var(--text3)}
.doc-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:7px;margin-top:4px}
.doc-card{border:0.5px solid var(--border);border-radius:var(--r);padding:9px 10px;display:flex;align-items:center;gap:8px;font-size:12px;text-decoration:none;transition:.12s}
.doc-card.has{border-color:var(--teal);background:var(--teal-bg);color:var(--teal-dk, #04342C)}
.doc-card.no{background:var(--bg3);color:var(--text3)}
.doc-card .dc-i{font-size:17px;flex-shrink:0}
.doc-card .dc-n{flex:1;font-weight:500;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-size:11px}
.doc-card .dc-s{font-size:14px;flex-shrink:0}
.info-grid{display:grid;grid-template-columns:1fr 1fr;gap:7px;margin-top:4px}
.info-item{background:var(--bg3);border-radius:var(--r);padding:9px 10px;border:0.5px solid var(--border)}
.info-item .ii-lbl{font-size:10px;color:var(--text3);margin-bottom:3px;text-transform:uppercase;letter-spacing:.05em}
.info-item .ii-val{font-size:12px;font-weight:500;color:var(--text);overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.cred-grid{display:grid;grid-template-columns:1fr 1fr;gap:7px;margin-top:4px}
.cred-item{background:var(--amber-bg);border:0.5px solid var(--amber);border-radius:var(--r);padding:9px 10px}
.cred-lbl{font-size:10px;color:var(--amber);margin-bottom:3px;text-transform:uppercase;letter-spacing:.05em;font-weight:600}
.cred-val{font-size:13px;font-weight:600;color:var(--text);display:flex;align-items:center;gap:6px;word-break:break-all}
.eye-btn{background:none;border:none;cursor:pointer;color:var(--text3);padding:0;font-size:15px;flex-shrink:0}
.eye-btn:hover{color:var(--text)}

/* STUDENT VIEW / FILTERS */
.filter-bar2{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:10px;align-items:center}
.filter-sel{padding:6px 10px;border-radius:var(--r);font-size:12px;border:0.5px solid var(--border2);background:var(--bg2);color:var(--text);font-family:inherit;cursor:pointer;outline:none;max-width:160px}
.filter-sel:focus{border-color:var(--blue)}
.filter-sel.active{border-color:var(--blue);background:var(--blue-bg);color:var(--blue-dk)}
.view-toggle{display:flex;gap:2px;background:var(--bg3);padding:3px;border-radius:var(--r);border:0.5px solid var(--border);margin-left:auto}
.vt-btn{padding:5px 11px;border-radius:6px;font-size:12px;border:none;background:none;cursor:pointer;color:var(--text2);font-family:inherit;display:flex;align-items:center;gap:5px}
.vt-btn.active{background:var(--bg2);color:var(--text);box-shadow:0 1px 3px rgba(0,0,0,.08);font-weight:500}
.count-badge{background:var(--blue-bg);color:var(--blue-dk);font-size:11px;font-weight:600;padding:2px 8px;border-radius:20px;white-space:nowrap}
/* STUDENT PROFILE MODAL */
.sp-apps{display:flex;flex-direction:column;gap:0}
.sp-app-row{display:flex;align-items:center;gap:10px;padding:10px 12px;border-bottom:0.5px solid var(--border);cursor:pointer;transition:.1s;font-size:13px}
.sp-app-row:hover{background:var(--blue-bg)}
.sp-app-row:last-child{border-bottom:none}
.sp-app-num{width:22px;height:22px;border-radius:50%;background:var(--bg3);border:0.5px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:500;flex-shrink:0}
.doc-sum-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:6px;margin-top:6px}
.doc-sum-item{display:flex;align-items:center;gap:8px;padding:8px 10px;border-radius:var(--r);font-size:12px;border:0.5px solid var(--border)}
.doc-sum-item.has{background:var(--teal-bg);border-color:var(--teal);color:#04342C}
.doc-sum-item.no{background:var(--bg3);color:var(--text3)}
.doc-sum-item i{font-size:15px;flex-shrink:0}
.doc-sum-item a{color:inherit;text-decoration:none;font-weight:500;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1}
.doc-sum-item span{font-weight:500;flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
</style>
</head>
<body>

<!-- LOGIN SCREEN -->
<div id="login-screen">
  <div class="login-wrap">
    <div class="login-card">
      <div class="login-icon"><i class="ti ti-briefcase"></i></div>
      <div class="login-title">Job Tracker</div>
      <div class="login-sub">Work Abroad Schoters</div>
      <div class="login-err" id="login-err"><i class="ti ti-alert-circle"></i> Password salah, coba lagi.</div>
      <input type="password" class="login-input" id="pass-inp" placeholder="Masukkan password..." onkeydown="if(event.key==='Enter')tryLogin()">
      <button class="login-btn" onclick="tryLogin()">Masuk</button>
      <div class="login-note">Default password: <strong>workabroad2026</strong><br>Bisa diubah di Pengaturan.</div>
    </div>
  </div>
</div>

<!-- APP SCREEN -->
<div id="app-screen" style="display:none" class="app">
  <aside class="sidebar">
    <div class="sb-header">
      <div class="sb-brand"><i class="ti ti-briefcase"></i> Job Tracker</div>
      <div class="sb-sub">Work Abroad Schoters</div>
    </div>

    <div class="nav-sect">Menu</div>
    <div class="nav-item active" data-page="dashboard" onclick="showPage('dashboard',this)"><i class="ti ti-layout-dashboard"></i>Dashboard</div>
    <div class="nav-item" data-page="students" onclick="showPage('students',this)"><i class="ti ti-users"></i>Students</div>

    <div class="nav-sect">Program</div>
    <div class="nav-item" onclick="filterByProgram('all',this)"><i class="ti ti-world"></i>Semua Program</div>
    <div class="nav-item" onclick="filterByProgram('English',this)"><i class="ti ti-flag"></i>English</div>
    <div class="nav-item" onclick="filterByProgram('Tokutei Ginou',this)"><i class="ti ti-flag"></i>Tokutei Ginou</div>
    <div class="nav-item" onclick="filterByProgram('Ausbildung',this)"><i class="ti ti-flag"></i>Ausbildung</div>

    <div class="nav-sect">Lainnya</div>
    <div class="nav-item" data-page="settings" onclick="showPage('settings',this)"><i class="ti ti-settings"></i>Pengaturan</div>

    <div class="sb-footer">
      <div class="logout" onclick="logout()"><i class="ti ti-logout"></i> Keluar</div>
    </div>
  </aside>

  <div class="main">
    <div class="topbar">
      <div class="topbar-l">
        <div class="page-title" id="pg-title">Dashboard</div>
        <button class="btn sm" id="refresh-btn" onclick="loadData()"><i class="ti ti-refresh"></i> Refresh</button>
      </div>
      <div class="topbar-r">
        <div class="search-box"><i class="ti ti-search"></i><input type="text" placeholder="Cari nama / email..." oninput="setSearch(this.value)"></div>
      </div>
    </div>

    <div class="content">
      <div class="page active" id="page-dashboard"><div id="dash-inner"></div></div>
      <div class="page" id="page-students">
        <div class="filter-row" id="status-chips"></div>
        <div id="students-wrap"></div>
      </div>
